# ── Neurosity Crown ───────────────────────────────────────────────────────────
NEUROSITY_EMAIL=your@email.com
NEUROSITY_PASSWORD=yourpassword
NEUROSITY_DEVICE_ID=your-device-id

# ── Anthropic API (for post-flight CV analysis) ───────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── DJI Mini 2 SE video feed ──────────────────────────────────────────────────
# Option 1: DJI Fly RTMP → ffmpeg bridge (recommended)
#   Run: ffmpeg -i rtsp://192.168.x.x/live -f mjpeg http://localhost:8090/
#   Then set: DRONE_STREAM_URL=http://localhost:8090/
#
# Option 2: Screen mirror phone via scrcpy (no extra software on drone)
#   Run: scrcpy --video-source=display (crops DJI Fly video area)
#   Then capture that window with OBS → virtual webcam
#
# Option 3: Leave blank for simulated thermal frames (demo mode)
DRONE_STREAM_URL=

# ── DJI Mini 2 SE telemetry companion ─────────────────────────────────────────
# Run the companion script on the Android phone paired to the drone:
#   python3 telemetry_companion.py
# It reads DJI Fly's GPS via ADB and POSTs to /api/telemetry
# See README for full setup.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
