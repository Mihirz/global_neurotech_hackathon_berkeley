# Neurosity Crown credentials
NEUROSITY_EMAIL=your@email.com
NEUROSITY_PASSWORD=yourpassword
NEUROSITY_DEVICE_ID=your-device-id

# Drone feed URL (MJPEG stream or WebRTC endpoint)
# Examples:
#   DJI: http://192.168.1.1:8080/video
#   Parrot: rtsp://192.168.42.1/live
#   Simulated: leave blank to use demo video
DRONE_STREAM_URL=

# Server port
PORT=3000
