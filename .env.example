# ── Emotiv Insight — Cortex API ───────────────────────────────────────────────
# 1. Create an EmotivID at https://www.emotiv.com
# 2. Register a Cortex app at https://www.emotiv.com/pages/developer
#    → you'll get a Client ID and Client Secret
# 3. Install and run the EMOTIV Launcher on your PC
#    → it hosts the Cortex WebSocket server at wss://localhost:6868
# 4. The first time you run the app, the Launcher will show an approval dialog
EMOTIV_CLIENT_ID=your-client-id
EMOTIV_CLIENT_SECRET=your-client-secret

# ── Anthropic API (post-flight CV analysis) ───────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── OpenAI API (post-flight CV analysis) ──────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# auto prefers OpenAI when OPENAI_API_KEY is set, then Anthropic.
# Set to openai or anthropic to force a provider.
CV_ANALYSIS_PROVIDER=auto

# ── DJI Mini 2 SE video feed ──────────────────────────────────────────────────
# Leave blank to use simulated thermal frames (demo mode)
DRONE_STREAM_URL=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
